# ─── NextForge Academy — Environment Variables ────────────────────────────────

# App
NODE_ENV=production
VITE_APP_NAME=NextForge Academy
VITE_APP_URL=https://your-domain.northflank.app

# Database (PostgreSQL via Prisma)
DATABASE_URL=postgresql://user:password@host:5432/nextforge_db

# Authentication
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your-refresh-token-secret

# Email (SMTP)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
EMAIL_FROM=noreply@nextforge.academy

# Cloud Storage (S3-compatible)
S3_BUCKET=nextforge-media
S3_REGION=us-east-1
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_ENDPOINT=https://s3.amazonaws.com

# Payment (Paystack)
VITE_PAYSTACK_PUBLIC_KEY=pk_live_2528949e9e36f7685c56ce98429cdb4457ae8d3b
PAYSTACK_SECRET_KEY=sk_live_your_paystack_secret_key
# USD to NGN exchange rate (update regularly or use FX API)
VITE_USD_TO_NGN_RATE=1600

# Redis (for sessions/caching)
REDIS_URL=redis://localhost:6379

# Northflank
PORT=80
